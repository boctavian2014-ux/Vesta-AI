# Baza de date (opțional). Dacă nu setezi, se folosește SQLite: ./imobiliare.db
# DATABASE_URL=sqlite:///./imobiliare.db
# Railway Postgres: DATABASE_URL=postgresql://user:pass@host:5432/dbname
# Supabase: Project Settings → Database → Connection string (URI). Backend-ul folosește automat SSL + pooler.

# CORS (opțional). Pentru dev + app mobil lasă nesetat. Pentru producție: listează domeniile permise, separate prin virgulă.
# CORS_ORIGINS=https://openhouse.vercel.app,https://vesta.app

# Stripe (Dashboard: https://dashboard.stripe.com/apikeys) – necesar pentru plată 19€
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# App mobil (Expo): setează în .env din openhouse-mobile sau la build: EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Imagini satelit (analiză piscină / abandon) – opțional
GOOGLE_MAPS_API_KEY=

# Analiză AI (GPT-4o + Mapbox satelit) și OCR Nota Simple (Vision) – opțional
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4o
MAPBOX_ACCESS_TOKEN=

# Verificare SSL Catastro: pune fnmt_root.pem în rădăcina proiectului (vezi BACKEND.md) și debifează:
# CATASTRO_CA_BUNDLE=./fnmt_root.pem

# Opțional: SMTP pentru notificări (când activezi email real)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=notificari@platforma-ta.ro
# SMTP_PASSWORD=...
