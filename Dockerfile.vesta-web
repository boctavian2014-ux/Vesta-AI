# vesta-web — build Node app from monorepo folder `web/` when deploy context is the full repo.
# Railway: service uses `web/railway.json` (config-as-code) with dockerfilePath pointing here.
# Root directory should be repo root so `web/` exists in the build context.

FROM node:22-bookworm-slim

WORKDIR /app

COPY web/package.json web/package-lock.json ./
RUN npm ci

COPY web/ ./
RUN npm run build

ENV NODE_ENV=production
EXPOSE 5000
CMD ["node", "dist/index.cjs"]
