# Copy to .env in this folder (never commit .env).

# Google Maps – Android native (react-native-maps), read by android/app/build.gradle
# GOOGLE_MAPS_API_KEY=

# Mapbox – public token, only if you use MapScreenMapbox (see MAPBOX_SETUP.md)
# EXPO_PUBLIC_MAPBOX_TOKEN=pk.eyJ1...

# Mapbox – secret “downloads” token for Gradle (EAS secret or local gradle.properties)
# RNMAPBOX_MAPS_DOWNLOAD_TOKEN=sk.eyJ1...
